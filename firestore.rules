rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Entity Validations ---

    function isValidUser(data) {
      let required = ['uid', 'email', 'role', 'createdAt'];
      return data.keys().hasAll(required) &&
             data.keys().size() >= 4 && data.keys().size() <= 10 &&
             data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 256 &&
             data.role in ['customer', 'driver', 'vendor'] &&
             data.createdAt == request.time &&
             (!('name' in data) || (data.name is string && data.name.size() <= 100)) &&
             (!('phone' in data) || (data.phone is string && data.phone.size() <= 20)) &&
             (!('isVerified' in data) || data.isVerified is bool) &&
             (!('documents' in data) || (data.documents is list && data.documents.size() <= 10));
    }

    function isValidBooking(data) {
      let required = ['customerId', 'pickup', 'drop', 'truckType', 'status', 'fare', 'createdAt', 'updatedAt'];
      return data.keys().hasAll(required) &&
             data.keys().size() >= 8 && data.keys().size() <= 12 &&
             data.customerId == request.auth.uid &&
             data.truckType is string && data.truckType.size() <= 100 &&
             data.status in ['pending', 'accepted', 'on-transit', 'completed', 'cancelled'] &&
             data.fare is number &&
             data.pickup is map && data.pickup.address is string && data.pickup.address.size() <= 500 &&
             data.drop is map && data.drop.address is string && data.drop.address.size() <= 500 &&
             data.createdAt == request.time &&
             data.updatedAt == request.time;
    }

    function isValidTruck(data) {
      let required = ['ownerId', 'type', 'regNumber', 'capacity', 'status'];
      return data.keys().hasAll(required) &&
             data.keys().size() == 5 &&
             data.ownerId == request.auth.uid &&
             data.type is string && data.type.size() <= 50 &&
             data.regNumber is string && data.regNumber.size() <= 20 &&
             data.capacity is string && data.capacity.size() <= 20 &&
             data.status in ['active', 'maintenance', 'inactive'];
    }

    // --- Collections ---

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && (isOwner(userId) || resource.data.role in ['driver', 'vendor']);
      allow create: if isValidId(userId) && isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && 
                    incoming().uid == existing().uid &&
                    incoming().role == existing().role &&
                    incoming().createdAt == existing().createdAt &&
                    (!('isVerified' in incoming()) || incoming().isVerified == existing().isVerified) &&
                    isValidUser(incoming());
    }

    match /bookings/{bookingId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && (
        resource.data.customerId == request.auth.uid || 
        resource.data.driverId == request.auth.uid || 
        resource.data.vendorId == request.auth.uid ||
        (resource.data.status == 'pending' && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'driver')
      );
      
      allow create: if isValidId(bookingId) && isSignedIn() && isValidBooking(incoming()) && incoming().status == 'pending';
      
      allow update: if isSignedIn() && (
        // Action: Cancel
        (isOwner(existing().customerId) && 
         incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']) &&
         incoming().status == 'cancelled' &&
         existing().status in ['pending', 'accepted'] &&
         incoming().updatedAt == request.time) ||
        
        // Action: Accept (Driver)
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'driver' &&
         existing().status == 'pending' &&
         incoming().diff(existing()).affectedKeys().hasOnly(['status', 'driverId', 'updatedAt']) &&
         incoming().status == 'accepted' &&
         incoming().driverId == request.auth.uid &&
         incoming().updatedAt == request.time) ||
        
        // Action: Progress (Driver)
        (existing().driverId == request.auth.uid &&
         incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']) &&
         ((existing().status == 'accepted' && incoming().status == 'on-transit') ||
          (existing().status == 'on-transit' && incoming().status == 'completed')) &&
         incoming().updatedAt == request.time)
      );
    }

    match /trucks/{truckId} {
      allow read: if isSignedIn();
      allow create: if isValidId(truckId) && isSignedIn() && isValidTruck(incoming());
      allow update: if isOwner(existing().ownerId) && isValidTruck(incoming());
      allow delete: if isOwner(existing().ownerId);
    }
  }
}
